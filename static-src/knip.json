{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["app.ts", "**/*.test.ts", "**/*.property.test.ts"],
  "project": ["**/*.ts", "!**/*.d.ts", "!node_modules/**"],
  "ignoreDependencies": [
    "eslint",
    "prettier",
    "typescript-eslint",
    "@eslint/js",
    "@vitest/coverage-v8"
  ],
  "ignoreBinaries": ["tsgo"],
  "ignoreMembers": [],
  "treatConfigHintsAsErrors": true,
  "includeEntryExports": true,
  "typescript": {
    "config": ["tsconfig.json", "tsconfig.test.json"]
  }
}
