{
  "type": "module",
  "scripts": {
    "typecheck": "tsc -project tsconfig.json",
    "typecheck:tests": "tsc -project tsconfig.test.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
