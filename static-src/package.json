{
  "type": "module",
  "scripts": {
    "typecheck": "tsgo -project tsconfig.json",
    "typecheck:tests": "tsgo -project tsconfig.test.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check ../..",
    "lint:fix": "eslint . --fix && prettier --write ../..",
    "lint:knip": "knip"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "fast-check": "4.8.0",
    "happy-dom": "20.10.1",
    "html-validate": "11.5.2",
    "knip": "6.15.0",
    "prettier": "3.8.3",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@cplieger/vterm": "1.1.0"
  }
}
