# Build artifacts (generated by `go generate ./...` locally and the
# Dockerfile build stage in prod). Sources of truth live under static-src/.
static/*.js
static/wire/
node_modules/
.vitest-cache/
static-src/coverage/

# Local `go build` output. The Dockerfile builds to /vibecli in the builder
# stage (COPY --from=builder /vibecli); a bare `go build` in the repo root
# drops the same binary here. Never commit it (OSSF Scorecard Binary-Artifacts).
/vibecli


static/style.css

# Kiro skill artifacts (code-review, refactor, steering-maintenance, judgement)
**/.code-review/
**/.judgement/
**/.refactor/
**/.steering-maintenance/

# Local rebuild dev loop (scripts/dev-build.sh) — not for CI/release
go.work
go.work.sum
vibecli-dev-bin
static/vendor/
