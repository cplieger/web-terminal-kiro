# Dev-only build artifacts; production uses vendored TS via tsc at Docker build time.
static/*.js
static/*.js.map
static/wire/
static/*.test.js


# Local-dev Go workspace (resolves the unpublished engine via a replace);
# never used in the image build, which resolves from the module proxy. Leaving
# it in the build context makes `go build` follow the replace to a path that
# does not exist in the container.
go.work
go.work.sum
# Dev-time installs / generated vendor tree; the image build fetches pinned
# tarballs itself and must never see local copies.
static-src/node_modules/
static/vendor/
# Local dev binary from scripts/dev-build.sh; never part of the image build.
web-terminal-kiro-dev-bin
