{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "timezone": "Europe/Paris",
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies"
    },
    {
      "description": "tsgo / TypeScript 7 native preview. Tracks the latest dist-tag (Microsoft's curated channel with up-to-date Go-stdlib CVE fixes). tsgo emits the browser JS bundle at build time, so every bump needs a rebuild. CLEANUP WHEN TS 7 IS STABLE: drop followTag + ignoreUnstable, restore default release cadence.",
      "matchPackageNames": ["@typescript/native-preview"],
      "followTag": "latest",
      "ignoreUnstable": false
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm dev dependencies",
      "schedule": ["before 6am on monday"]
    }
  ],
  "customDatasources": {
    "kiro-cli": {
      "defaultRegistryUrlTemplate": "https://desktop-release.q.us-east-1.amazonaws.com/index.json",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": versions.{ \"version\": version, \"digest\": packages[fileType = 'zip' and targetTriple = 'x86_64-unknown-linux-gnu' and variant = 'headless'][0].sha256 } }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Dockerfile ARG versions with renovate comments",
      "managerFilePatterns": ["/Dockerfile$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+depName=(?<depName>[^\\s]+)(\\s+versioning=(?<versioning>[a-z-]+))?\\nARG\\s+\\w+=(?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "golangci-lint version in workflows",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.yaml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[a-z-]+)\\s+depName=(?<depName>[^\\s]+)(\\s+versioning=(?<versioning>[a-z-]+))?\\s*\\n\\s*VERSION=(?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "kiro-cli version + sha256 pinned in entrypoint.sh",
      "managerFilePatterns": ["/entrypoint\\.sh$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>custom\\.kiro-cli)\\s+depName=(?<depName>[^\\s]+)\\s*\\nKIRO_CLI_VERSION=\"(?<currentValue>[^\"]+)\"\\s*\\nKIRO_CLI_SHA256=\"(?<currentDigest>[^\"]+)\""
      ],
      "versioningTemplate": "semver"
    }
  ],
  "ignorePaths": ["compose.yaml"],
  "dependencyDashboardLabels": ["renovate"]
}
